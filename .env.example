# --- Auth (NextAuth v5 / Auth.js) ---
# Generá con: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Único email autorizado para login (Google y credentials)
AUTH_ALLOWED_EMAIL=mantovanimariano@transfil.com.ar

# Password dummy para login con credenciales (bcrypt hash)
# Generá con: node -e "console.log(require('bcryptjs').hashSync('soymarianito', 10))"
AUTH_DUMMY_PASSWORD_HASH=

# URL de la app (en local: http://localhost:3000)
AUTH_URL=http://localhost:3000

