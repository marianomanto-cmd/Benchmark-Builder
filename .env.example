# ── Supabase (públicas; inyectadas en Vercel por la integración Supabase↔Vercel)
NEXT_PUBLIC_SUPABASE_URL=https://wjexqyliwwsxjdujgwjo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_WXZoC55lha6WYyQMkTMh-g_K9XRDrTx

# ── Supabase service role (SECRETO) — necesario para que el runner escriba menciones.
# Supabase Dashboard → Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=

# ── Modo del pipeline. mock (default) = fixtures deterministas + costo simulado
# (valida el flujo completo a costo cero). live = llamadas reales, pero SOLO si
# además el flag del proveedor está on en system_flags Y la API key está presente.
PIPELINE_MODE=mock

# ── IA · análisis de sentimiento + generación de insights (proveedor configurable)
AI_PROVIDER=claude            # "claude" (default) o "grok"
# Anthropic Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=
# Modelos de orquestación (opcional; defaults razonables):
# ANTHROPIC_WIZARD_MODEL=claude-haiku-4-5-20251001   # asistente del wizard (económico)
# ANTHROPIC_PLANNER_MODEL=claude-opus-4-8            # planner → queries acotadas
# xAI Grok — https://console.x.ai (lee X y hace búsqueda web+prensa independiente)
XAI_API_KEY=
XAI_MODEL=grok-3

# ── Apify (scraping de Instagram, TikTok, X, YouTube, Facebook, Web)
# https://console.apify.com/account/integrations
APIFY_TOKEN=
# Overrides opcionales de actor por plataforma (si no, se usan defaults razonables):
# APIFY_ACTOR_INSTAGRAM=apify~instagram-scraper
# APIFY_ACTOR_TIKTOK=clockworks~tiktok-scraper
# APIFY_ACTOR_YOUTUBE=streamers~youtube-scraper
# APIFY_ACTOR_FACEBOOK=apify~facebook-posts-scraper
# APIFY_ACTOR_X=apidojo~tweet-scraper
# APIFY_ACTOR_WEB=apify~google-search-scraper

# ── Meta Ad Library — DEPRECADO como vía principal (decisión de producto):
# la API oficial NO se usa; los anuncios se detectan vía SCRAPERS
# (Apify ad-library / ad-detection actors). Dejar vacío salvo reactivación puntual.
META_AD_LIBRARY_TOKEN=

# ── Pipeline de medios (Task 2) — análisis de imagen/video + transcripción de voiceover
# Imágenes/frames: Claude vision. Video: Gemini NATIVO (imagen+audio en una sola
# llamada) si hay GOOGLE_AI_API_KEY; si no, fallback a frames (ffmpeg) + Claude
# vision + OpenAI Whisper.
# OpenAI Whisper (transcripción) — https://platform.openai.com/api-keys
OPENAI_API_KEY=
# OPENAI_TRANSCRIBE_MODEL=whisper-1
# Modelo de visión (Claude) para imágenes/frames:
# ANTHROPIC_VISION_MODEL=claude-opus-4-8
#
# ── Multimodal · Gemini — análisis NATIVO de video (imagen+audio) — https://aistudio.google.com/app/apikey
# Live sólo si: PIPELINE_MODE=live + flag gemini_enabled en system_flags + esta key.
GOOGLE_AI_API_KEY=
# GOOGLE_AI_VIDEO_MODEL=gemini-2.5-flash
# AssemblyAI para voiceover/transcripción de calidad (diarización, timestamps) — https://www.assemblyai.com
# ASSEMBLYAI_API_KEY=
# ffmpeg para extraer frames/audio en live (en Vercel: agregar `ffmpeg-static` y apuntar acá):
# FFMPEG_PATH=/path/to/ffmpeg

# ── Brave Search (opcional)
# BRAVE_API_KEY=

# ── Mastodon (opcional; default mastodon.social, sin token para timelines públicos)
# MASTODON_INSTANCE=mastodon.social

# Reddit y Bluesky usan APIs públicas (sin token).

# ── Seguridad opcional de endpoints
# RUN_TRIGGER_SECRET=    # si se setea, /api/runs exige header x-run-secret
# CRON_SECRET=           # si se setea, /api/cron/cost exige Authorization: Bearer <secret>

# ── Overrides opcionales del motor de costos (ver lib/cost/rates.ts, estimate.ts, config.ts)
# RATE_ANTHROPIC_INPUT_PER_MTOK=5  RATE_ANTHROPIC_OUTPUT_PER_MTOK=25  RATE_APIFY_PER_RESULT=0.004
# RATE_WHISPER_PER_MINUTE=0.006  RATE_GEMINI_VIDEO_PER_CLIP=0.01  EST_BAND_LOW=0.85  EST_BAND_HIGH=1.3
# ALERT_RUN_OVER_USD=50  ALERT_PROVIDER_DAILY_USD=100  ALERT_ACCEL_FACTOR=5
# MAX_CLAUDE_CALLS_PER_RUN=200  MAX_FRAMES_PER_VIDEO=8  MAX_VIDEOS_PER_RUN=20  MAX_ITEMS_PER_SOURCE=100
