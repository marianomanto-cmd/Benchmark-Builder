# =====================================================================
# Estas variables se setean en Vercel (Project → Settings → Environment
# Variables). En local sólo si vas a correr `pnpm dev` contra Supabase.
# =====================================================================

# --- Supabase (Auth + DB + Realtime + Storage) ---
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — SOLO server-side (route handlers, server actions). Nunca exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# Connection string para Drizzle (Fase 2) — Project Settings → Database → Connection string
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-...pooler.supabase.com:6543/postgres

# --- Allowlist (single-user) ---
# Único email autorizado. Google OAuth y email/password validan contra esto.
AUTH_ALLOWED_EMAIL=mantovanimariano@transfil.com.ar

# =====================================================================
# Setup de auth en Supabase (una vez, desde el dashboard):
#   1. Authentication → Providers → Google: pegar Client ID/Secret de Google
#      Cloud Console. Redirect URL: https://<TU-PROYECTO>.supabase.co/auth/v1/callback
#   2. Authentication → URL Configuration → Site URL: https://<tu-app>.vercel.app
#      Redirect URLs: agregar https://<tu-app>.vercel.app/auth/callback
#   3. Authentication → Users → Add user: crear
#      mantovanimariano@transfil.com.ar con password "soymarianito"
#      y marcar "Auto Confirm User".
# =====================================================================

# --- LLM (Fase 2) ---
# XAI_API_KEY=

# --- Apify (Fase 3) ---
# APIFY_TOKEN=
