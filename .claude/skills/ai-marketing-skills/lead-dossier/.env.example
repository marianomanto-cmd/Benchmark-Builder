# Lead Dossier — Environment Variables
# Copy this file to .env and fill in your API keys.

# People Search API (e.g., Apollo, ZoomInfo, Clearbit)
LEAD_SOURCE_API_KEY=your-people-search-api-key
LEAD_SOURCE_API_URL=https://api.apollo.io/api/v1/mixed_people/search

# Email Validation API (e.g., LeadMagic, ZeroBounce, NeverBounce, Hunter)
EMAIL_VALIDATION_API_KEY=your-email-validation-api-key
EMAIL_VALIDATION_API_URL=https://api.your-email-provider.com/v1/people/email-validation

# Campaign Tool API (e.g., Instantly, Lemlist, Smartlead)
CAMPAIGN_TOOL_API_KEY=your-campaign-tool-api-key
CAMPAIGN_API_BASE_URL=https://api.your-campaign-tool.com/api/v2

# CRM API (e.g., HubSpot, Salesforce, Pipedrive)
CRM_API_KEY=your-crm-api-key
CRM_BASE_URL=https://api.hubapi.com
CRM_PORTAL_ID=your-portal-id

# BuiltWith API (free tier key works, or use "free")
BUILTWITH_API_KEY=free
